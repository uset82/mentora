NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Production default
AI_PROVIDER=openai
OPENAI_API_KEY=sk-proj-your-openai-key
OPENAI_CHAT_MODEL_FAST=gpt-5.4-mini
OPENAI_CHAT_MODEL_QUALITY=gpt-5.5
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_EMBEDDING_DIMENSIONS=1536

# Free/low-cost testing mode through OpenRouter.
# Set AI_PROVIDER=openrouter to route text generation here.
# OpenAI is still required for PDF ingestion and RAG retrieval embeddings.
OPENROUTER_API_KEY=sk-or-v1-your-openrouter-key
OPENROUTER_MODEL=openrouter/free
OPENROUTER_APP_NAME=Mentora
OPENROUTER_APP_URL=http://localhost:3000

# Local dev auto-login only. Never expose real credentials in client builds.
NEXT_PUBLIC_MENTORA_DEV_AUTOLOGIN=false
NEXT_PUBLIC_MENTORA_DEV_EMAIL=dev@example.com
NEXT_PUBLIC_MENTORA_DEV_PASSWORD=dev-password
